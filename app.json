{
  "expo": {
    "name": "Live Monitor",
    "slug": "streamrecorder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "owner": "lucifure",
    "icon": "./icon.png",
    "splash": {
      "backgroundColor": "#111B21",
      "image": "./icon.png",
      "resizeMode": "contain"
    },
    "extra": {
      "eas": {
        "projectId": "5c73c043-a676-4830-aaf1-d9f17a279ecf"
      }
    },
    "android": {
      "package": "com.streamrecorder.app",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#111B21"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    }
  }
}
